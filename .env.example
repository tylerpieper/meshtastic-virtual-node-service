# .env.example
# Define environment variables used by the virtual node docker-compose

# The host directory where the Meshtastic configuration and database will be stored
DATA_DIR=./data

# Define the official meshtasticd docker image tag (e.g. beta-debian, latest)
IMAGE_TAG=beta-debian

# Leave empty to generate a random MAC address, or provide a specific one (e.g. AA:BB:CC:DD:EE:FF)
MAC_ADDRESS=

# Identity
NODE_LONG_NAME=Virtual Node
NODE_SHORT_NAME=VIRT
NODE_ROLE=1

# Channel Configuration
CHANNEL_NAME=LongFast
# Default AQ== is the standard "Default" encryption key in Meshtastic
CHANNEL_KEY=AQ==

# Fixed GPS Position
LATITUDE=32.10
LONGITUDE=-110.85
POSITION_PRECISION=14

# API Access Port
API_PORT=44404

# Advanced Radio Config
HOP_LIMIT=7
